{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/local-ultra-review/candidate-finding.schema.json",
  "title": "CandidateFinding",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "severity",
    "category",
    "file",
    "line",
    "introduced_by_diff",
    "failure_scenario",
    "evidence",
    "verification_plan",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "severity": {
      "type": "string",
      "enum": [
        "Important",
        "Nit",
        "Pre-existing",
        "NeedsManualReview"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "correctness",
        "security",
        "privacy",
        "integration",
        "test",
        "performance",
        "migration",
        "concurrency",
        "state",
        "configuration",
        "other"
      ]
    },
    "file": {
      "type": "string",
      "minLength": 1
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "introduced_by_diff": {
      "type": "boolean"
    },
    "failure_scenario": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "file",
          "line",
          "reason"
        ],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verification_plan": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "reviewer": {
      "type": "string"
    },
    "suggested_fix_direction": {
      "type": "string"
    }
  }
}
